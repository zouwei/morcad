{
  "id": "morcad",
  "name": "MorCad CAD Viewer",
  "version": "0.1.7",
  "description": "Renders DXF/DWG engineering drawings inline as code blocks",
  "author": "zouwei",
  "license": "GPL-3.0",
  "apiVersion": "1",
  "entry": {
    "darwin-aarch64": "bin/morcad",
    "darwin-x86_64": "bin/morcad",
    "win32": "bin/morcad.exe",
    "linux-x86_64": "bin/morcad"
  },
  "protocol": "jsonrpc-stdio",
  "permissions": [
    "editor:read"
  ],
  "permissionReasons": {
    "editor:read": "Read current document path to resolve relative DXF file paths"
  },
  "sandboxLevel": "standard",
  "homepage": "https://github.com/zouwei/morcad",
  "cdnUrl": "https://cdn.jsdelivr.net/gh/zouwei/morcad@v0.1.7/packages/moraya/dist/index.bundle.js"
}
